# Database
# For Neon: DATABASE_URL uses the pooled (-pooler) endpoint, DIRECT_DATABASE_URL uses the direct endpoint.
# Prisma uses DIRECT_DATABASE_URL for migrations (advisory locks require a direct connection).
DATABASE_URL=postgresql://user:password@localhost:5432/cleared
DIRECT_DATABASE_URL=postgresql://user:password@localhost:5432/cleared

# Authentication
NEXTAUTH_SECRET=generate-a-random-string-here
NEXTAUTH_URL=http://localhost:3000

# AI Services
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...        # For knowledge base embeddings only

# File Storage (AWS S3)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=cleared-documents

# Security
ENCRYPTION_KEY=generate-a-32-char-random-string

# Junebug Full Fetch — "Jarvis mode" deployment diagnostics (optional).
# When both VERCEL_API_TOKEN and VERCEL_PROJECT_ID are set, Full Fetch
# turns pull the latest deployment state + build-log tail + recent
# runtime events into the system prompt so Junebug can answer
# "is the site deployed?" / "what broke on the last build?". Leave
# both unset in local dev; Full Fetch then skips the Vercel call
# without any error noise.
#
# Token: Vercel dashboard → Account Settings → Tokens. Scope to the
# project (or team). Read-only access is sufficient — Junebug never
# mutates Vercel state from here.
# VERCEL_API_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=   # only if the token is team-scoped

