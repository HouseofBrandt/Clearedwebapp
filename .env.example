# Database
# For Neon: DATABASE_URL uses the pooled (-pooler) endpoint, DIRECT_DATABASE_URL uses the direct endpoint.
# Prisma uses DIRECT_DATABASE_URL for migrations (advisory locks require a direct connection).
DATABASE_URL=postgresql://user:password@localhost:5432/cleared
DIRECT_DATABASE_URL=postgresql://user:password@localhost:5432/cleared

# Authentication
NEXTAUTH_SECRET=generate-a-random-string-here
NEXTAUTH_URL=http://localhost:3000

# AI Services
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...        # For knowledge base embeddings only

# File Storage (AWS S3)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=cleared-documents

# Security
ENCRYPTION_KEY=generate-a-32-char-random-string

# Feature flags
# Junebug Threads (A4.7) — persistent multi-thread chat workspace.
# Leave "false" during rollout. See docs/spec-junebug-threads.md §8.
NEXT_PUBLIC_JUNEBUG_THREADS_ENABLED=false

# Optional beta gate: comma-separated email domains that can see Junebug
# when the global flag above is "true". Leave empty (or unset) to expose
# Junebug to everyone once the flag is on. Server-only — not NEXT_PUBLIC
# so the list doesn't leak to the client bundle.
#
# Example internal rollout:
#   NEXT_PUBLIC_JUNEBUG_THREADS_ENABLED=true
#   JUNEBUG_BETA_EMAIL_DOMAINS=yourfirm.com
JUNEBUG_BETA_EMAIL_DOMAINS=
