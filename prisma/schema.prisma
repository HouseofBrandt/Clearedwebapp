generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  PRACTITIONER
  SENIOR
  ADMIN
  SUPPORT_STAFF
}

enum LicenseType {
  EA
  CPA
  ATTORNEY
}

enum CaseStatus {
  INTAKE
  ANALYSIS
  REVIEW
  ACTIVE
  RESOLVED
  CLOSED
}

enum CaseType {
  OIC
  IA
  PENALTY
  INNOCENT_SPOUSE
  CNC
  TFRP
  ERC
  UNFILED
  AUDIT
  CDP
  AMENDED
  VOLUNTARY_DISCLOSURE
  OTHER
}

enum FilingStatus {
  SINGLE
  MFJ
  MFS
  HOH
  QSS
}

enum FileType {
  PDF
  IMAGE
  DOCX
  XLSX
  TEXT
  AUDIO
}

enum DocumentCategory {
  IRS_NOTICE
  IRS_REJECTION
  BANK_STATEMENT
  TAX_RETURN
  PAYROLL
  MEDICAL
  MEETING_NOTES
  UTILITY_BILL
  VEHICLE_LOAN
  STUDENT_LOAN
  RETIREMENT_ACCOUNT
  MORTGAGE_STATEMENT
  INSURANCE
  PAY_STUB
  MEETING_RECORDING
  VOICE_NOTE
  OTHER
}

enum AITaskType {
  WORKING_PAPERS
  CASE_MEMO
  PENALTY_LETTER
  OIC_NARRATIVE
  GENERAL_ANALYSIS
  IA_ANALYSIS
  CNC_ANALYSIS
  TFRP_ANALYSIS
  INNOCENT_SPOUSE_ANALYSIS
  APPEALS_REBUTTAL
  CASE_SUMMARY
  RISK_ASSESSMENT
  WEB_RESEARCH
}

// ─── Client Notes & Conversations ───

enum NoteType {
  JOURNAL_ENTRY
  CALL_LOG
  IRS_CONTACT
  STRATEGY_NOTE
  CLIENT_INTERACTION
  RESEARCH
  GENERAL
}

enum NoteVisibility {
  ALL_PRACTITIONERS
  CASE_TEAM_ONLY
  PRIVATE
}

enum FeatureArea {
  TRANSCRIPT_DECODER
  CASE_INTELLIGENCE
  PENALTY_ABATEMENT
  OIC
  COMPLIANCE
  DEADLINE_TRACKER
  GENERAL
}

enum ConversationStatus {
  OPEN
  RESOLVED
  ARCHIVED
}

enum ConversationPriority {
  NORMAL
  URGENT
  FYI
}

// ─── SOC 2 Compliance ───

enum TSC {
  SECURITY
  AVAILABILITY
  PROCESSING_INTEGRITY
  CONFIDENTIALITY
  PRIVACY
}

enum ControlStatus {
  COMPLIANT
  PARTIALLY_COMPLIANT
  NON_COMPLIANT
  NOT_ASSESSED
}

enum MonitoringMethod {
  AUTOMATED
  MANUAL
  HYBRID
}

enum IssueSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  IMPLEMENTED
  VERIFIED
  CLOSED
  ACCEPTED_RISK
}

enum EvidenceType {
  AUTOMATED_LOG
  CONFIG_SNAPSHOT
  POLICY_DOCUMENT
  MANUAL_UPLOAD
  TEST_RESULT
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

enum BanjoStatus {
  PLANNING
  CLARIFYING
  AWAITING_APPROVAL
  EXECUTING
  POLISHING
  COMPLETED
  FAILED
  CANCELLED

  @@map("banjo_status")
}

enum AITaskStatus {
  QUEUED
  PROCESSING
  READY_FOR_REVIEW
  APPROVED
  REJECTED
  SKIPPED
}

enum ReviewActionType {
  APPROVE
  EDIT_APPROVE
  REJECT_REPROMPT
  REJECT_MANUAL
}

enum KnowledgeCategory {
  IRC_STATUTE
  TREASURY_REGULATION
  IRM_SECTION
  REVENUE_PROCEDURE
  REVENUE_RULING
  CASE_LAW
  TREATISE
  FIRM_TEMPLATE
  WORK_PRODUCT
  APPROVED_OUTPUT
  FIRM_PROCEDURE
  TRAINING_MATERIAL
  CLIENT_GUIDE
  CUSTOM
}

enum MessageType {
  DIRECT_MESSAGE
  BUG_REPORT
  FEATURE_REQUEST
  DEADLINE_REMINDER
  REVIEW_ASSIGNED
  TASK_APPROVED
  TASK_REJECTED
  SYSTEM_ANNOUNCEMENT
  CASE_NOTE
}

enum MessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum DeadlineType {
  CDP_HEARING
  EQUIVALENT_HEARING
  TAX_COURT_PETITION
  CSED_EXPIRATION
  ASSESSMENT_STATUTE
  OIC_SUBMISSION
  OIC_PAYMENT
  OIC_COMPLIANCE
  IA_PAYMENT
  RETURN_DUE
  EXTENSION_DUE
  ESTIMATED_TAX
  IRS_RESPONSE
  DOCUMENT_REQUEST
  POA_RENEWAL
  FOLLOW_UP
  HEARING_DATE
  MEETING
  INTERNAL_REVIEW
  CUSTOM
}

enum DeadlinePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum DeadlineStatus {
  UPCOMING
  DUE_SOON
  OVERDUE
  COMPLETED
  WAIVED
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  passwordHash   String
  role           Role      @default(PRACTITIONER)
  licenseType    LicenseType?
  licenseNumber  String?
  mfaEnabled     Boolean   @default(false)
  mfaSecret      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  assignedCases       Case[]         @relation("AssignedPractitioner")
  uploadedDocs        Document[]
  reviewActions       ReviewAction[]
  auditLogs           AuditLog[]
  aiTasks             AITask[]
  completedDeadlines  Deadline[]     @relation("CompletedDeadlines")
  assignedDeadlines   Deadline[]     @relation("AssignedDeadlines")
  createdDeadlines    Deadline[]     @relation("CreatedDeadlines")
  uploadedKnowledge   KnowledgeDocument[] @relation("UploadedKnowledge")
  sentMessages        Message[]          @relation("SentMessages")
  receivedMessages    Message[]          @relation("ReceivedMessages")
  appErrors           AppError[]         @relation("UserErrors")
  implementedMessages Message[]          @relation("ImplementedMessages")
  caseActivities      CaseActivity[]     @relation("CaseActivities")
  banjoAssignments    BanjoAssignment[]
  feedPosts           FeedPost[]         @relation("FeedPosts")
  feedReplies         FeedReply[]        @relation("FeedReplies")
  feedLikes           FeedLike[]         @relation("FeedLikes")
  assignedFeedTasks   FeedPost[]         @relation("AssignedFeedTasks")
  feedReactions       FeedReaction[]     @relation("FeedReactions")
  feedMentions        FeedMention[]      @relation("FeedMentions")
  createdTasks        Task[]             @relation("CreatedTasks")
  assignedTasks       Task[]             @relation("AssignedTasks")
  completedTasks      Task[]             @relation("CompletedTasks")
  clientNotes         ClientNote[]       @relation("NoteAuthor")
  startedConversations Conversation[]    @relation("ConversationStarter")
  resolvedConversations Conversation[]   @relation("ConversationResolver")
  conversationMessages ConversationMsg[] @relation("MessageAuthor")

  // SOC 2 Policy Acknowledgment Gate
  policyAcknowledgments PolicyAcknowledgment[] @relation("PolicyAcknowledgments")
  securityTrainings     SecurityTraining[]     @relation("SecurityTrainings")
  backgroundChecks      BackgroundCheck[]      @relation("BackgroundChecks")
  backgroundCheckEntries BackgroundCheck[]     @relation("BackgroundCheckEntries")
  policiesCreated       CompliancePolicy[]     @relation("PolicyCreator")
  governanceMeetings    GovernanceMeeting[]    @relation("GovernanceMeetings")
  incidentsAssigned     IncidentRecord[]       @relation("IncidentAssignee")
  disposalsConfirmed    DataDisposalRecord[]   @relation("DisposalConfirmer")
  dsrAssigned           DataSubjectRequest[]   @relation("DSRAssignee")
  formInstances         FormInstance[]         @relation("FormInstances")
  workProductOverrides  WorkProductOverride[]  @relation("WorkProductOverrides")

  @@map("users")
}

model Case {
  id                    String     @id @default(cuid())
  tabsNumber            String     @unique
  clientName            String
  clientNameEncrypted   String?
  status                CaseStatus @default(INTAKE)
  caseType              CaseType   @default(OTHER)
  filingStatus          FilingStatus?
  clientEmail           String?
  clientPhone           String?
  totalLiability        Decimal?
  assignedPractitionerId String?
  assignedPractitioner  User?      @relation("AssignedPractitioner", fields: [assignedPractitionerId], references: [id])
  notes                 String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  documents          Document[]
  aiTasks            AITask[]
  tokenMaps          TokenMap[]
  auditLogs          AuditLog[]
  liabilityPeriods   LiabilityPeriod[]
  deadlines          Deadline[]
  messages           Message[]
  intelligence       CaseIntelligence?
  activities         CaseActivity[]
  banjoAssignments   BanjoAssignment[]
  feedPosts          FeedPost[]
  feedPostCases      FeedPostCase[]     @relation("FeedPostCases")
  tasks              Task[]
  clientNotes        ClientNote[]
  conversations      Conversation[]
  formInstances      FormInstance[]
  reasoningLogs      ReasoningPipelineLog[]

  @@index([tabsNumber])
  @@map("cases")
}

model Document {
  id               String           @id @default(cuid())
  caseId           String
  case             Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fileName         String
  filePath         String
  fileType         FileType
  fileSize         Int
  documentCategory DocumentCategory @default(OTHER)
  extractedText    String?
  statementDate    DateTime?
  expiresAt        DateTime?
  freshnessStatus  String?          // "fresh" | "expiring_soon" | "expired"
  uploadedById     String
  uploadedBy       User             @relation(fields: [uploadedById], references: [id])
  uploadedAt       DateTime         @default(now())

  @@map("documents")
}

model AITask {
  id                  String       @id @default(cuid())
  caseId              String
  case                Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  taskType            AITaskType
  status              AITaskStatus @default(QUEUED)
  tokenizedInput      String?      @db.Text
  tokenizedOutput     String?      @db.Text
  detokenizedOutput   String?      @db.Text
  modelUsed           String?
  temperature         Float?
  systemPromptVersion String?
  verifyFlagCount     Int          @default(0)
  judgmentFlagCount    Int          @default(0)
  requestId           String       @unique @default(uuid())
  metadata            Json?
  casePosture         Json?
  createdById         String?
  createdBy           User?        @relation(fields: [createdById], references: [id])
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  reviewActions ReviewAction[]
  auditLogs     AuditLog[]

  // Banjo assignment grouping (null for legacy standalone tasks)
  banjoAssignmentId  String?
  banjoAssignment    BanjoAssignment?  @relation(fields: [banjoAssignmentId], references: [id])
  banjoStepNumber    Int?
  banjoStepLabel     String?

  @@map("ai_tasks")
}

model ReviewAction {
  id               String           @id @default(cuid())
  aiTaskId         String
  aiTask           AITask           @relation(fields: [aiTaskId], references: [id], onDelete: Cascade)
  practitionerId   String
  practitioner     User             @relation(fields: [practitionerId], references: [id])
  action           ReviewActionType
  editedOutput     String?          @db.Text
  reviewNotes      String?
  reviewStartedAt   DateTime
  reviewCompletedAt  DateTime?
  flagsAcknowledged  Boolean   @default(false)

  @@map("review_actions")
}

model AuditLog {
  id             String   @id @default(cuid())
  aiTaskId       String?
  aiTask         AITask?  @relation(fields: [aiTaskId], references: [id])
  practitionerId String?
  practitioner   User?    @relation(fields: [practitionerId], references: [id])
  caseId         String?
  case           Case?    @relation(fields: [caseId], references: [id])
  action         String
  metadata       Json?
  timestamp      DateTime @default(now())

  @@map("audit_logs")
}

model LiabilityPeriod {
  id                 String    @id @default(cuid())
  caseId             String
  case               Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  taxYear            Int
  formType           String    // "1040", "941", etc.
  originalAssessment Decimal?
  penalties          Decimal?
  interest           Decimal?
  totalBalance       Decimal?
  assessmentDate     DateTime?
  csedDate           DateTime?
  status             String?   // "assessed", "paid", etc.

  @@map("liability_periods")
}

model TokenMap {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tokenMap  String   @db.Text
  createdAt DateTime @default(now())
  expiresAt DateTime?

  @@map("token_maps")
}

model Deadline {
  id              String           @id @default(cuid())
  caseId          String
  case            Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type            DeadlineType
  priority        DeadlinePriority @default(MEDIUM)
  status          DeadlineStatus   @default(UPCOMING)
  title           String
  description     String?
  dueDate         DateTime
  reminderDate    DateTime?
  completedDate   DateTime?
  completedById   String?
  completedBy     User?            @relation("CompletedDeadlines", fields: [completedById], references: [id])
  assignedToId    String?
  assignedTo      User?            @relation("AssignedDeadlines", fields: [assignedToId], references: [id])
  createdById     String?
  createdBy       User?            @relation("CreatedDeadlines", fields: [createdById], references: [id])
  source          String?
  sourceTaskId    String?
  irsNoticeDate   DateTime?
  irsNoticeNumber String?
  taxYear         Int?
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([caseId])
  @@index([dueDate])
  @@index([status])
  @@index([assignedToId])
  @@map("deadlines")
}

model KnowledgeDocument {
  id              String            @id @default(cuid())
  title           String
  description     String?
  category        KnowledgeCategory
  fileName        String?
  filePath        String?
  fileSize        Int?
  s3Key           String?
  processingStatus String           @default("ready") // uploading | processing | ready | failed
  processingError String?
  sourceText      String            @db.Text @default("")
  tags            String[]
  isActive        Boolean           @default(true)
  chunkCount      Int               @default(0)
  hitCount        Int               @default(0)
  uploadedById    String
  uploadedBy      User              @relation("UploadedKnowledge", fields: [uploadedById], references: [id])
  sourceTaskId    String?
  sourceCaseId    String?

  // Provenance
  sourceType        String            @default("MANUAL_UPLOAD")
  lastReferencedAt  DateTime?

  // V2: Outcome tagging (populated when source case is resolved)
  outcomeTag        String?           // OIC_ACCEPTED, OIC_REJECTED, IA_APPROVED, etc.
  outcomeAmount     Decimal?          // Final accepted amount (for OIC)

  // V2: Freshness scoring
  freshnessScore    Float             @default(1.0) // 0.0 (stale) to 1.0 (fresh)

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  chunks          KnowledgeChunk[]

  @@index([category])
  @@index([isActive])
  @@index([processingStatus])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id              String            @id @default(cuid())
  documentId      String
  document        KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex      Int
  content         String            @db.Text
  sectionHeader   String?
  tokenCount      Int?
  hitCount        Int               @default(0)
  metadata        Json?
  createdAt       DateTime          @default(now())

  // Managed via raw SQL in vector-setup.ts (pgvector extension)
  embedding       Unsupported("vector(1536)")?
  // search_vector is a GENERATED ALWAYS AS ... STORED tsvector column.
  // It cannot be declared here because Prisma tries to ALTER generated columns.
  // It is dropped before `prisma db push` and recreated by setup-vector.mjs.

  @@index([documentId])
  @@map("knowledge_chunks")
}

model AppError {
  id            String   @id @default(cuid())
  route         String
  method        String
  errorMessage  String   @db.Text
  errorStack    String?  @db.Text
  statusCode    Int?
  userId        String?
  user          User?    @relation("UserErrors", fields: [userId], references: [id])
  caseId        String?
  aiTaskId      String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([route])
  @@index([userId])
  @@index([createdAt])
  @@map("app_errors")
}

model Message {
  id            String          @id @default(cuid())
  type          MessageType
  priority      MessagePriority @default(NORMAL)
  subject       String
  body          String          @db.Text

  senderId      String?
  sender        User?           @relation("SentMessages", fields: [senderId], references: [id])
  senderName    String?

  recipientId   String
  recipient     User            @relation("ReceivedMessages", fields: [recipientId], references: [id])

  read          Boolean         @default(false)
  readAt        DateTime?
  archived      Boolean         @default(false)

  caseId        String?
  case          Case?           @relation(fields: [caseId], references: [id], onDelete: SetNull)
  deadlineId    String?
  aiTaskId      String?

  parentId      String?
  parent        Message?        @relation("Replies", fields: [parentId], references: [id], onDelete: SetNull)
  replies       Message[]       @relation("Replies")

  tags          String[]
  metadata      Json?

  // Implementation tracking (for BUG_REPORT and FEATURE_REQUEST)
  implementationStatus  String?
  implementationNotes   String?   @db.Text
  implementedAt         DateTime?
  implementedById       String?
  implementedBy         User?     @relation("ImplementedMessages", fields: [implementedById], references: [id])

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([recipientId, read])
  @@index([recipientId, type])
  @@index([type, createdAt])
  @@index([caseId])
  @@map("messages")
}

model CaseIntelligence {
  id                    String    @id @default(cuid())
  caseId                String    @unique
  case                  Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Resolution tracking
  resolutionType        String?
  resolutionPhase       String    @default("GATHERING_DOCUMENTS")

  // IRS position tracking
  irsLastAction         String?
  irsLastActionDate     DateTime?
  irsNextExpectedAction String?
  irsAssignedUnit       String?
  irsAssignedEmployee   String?
  irsEmployeeId         String?

  // Document completeness
  docsRequired          Json      @default("[]")
  docsReceivedCount     Int       @default(0)
  docsRequiredCount     Int       @default(0)
  docCompleteness       Float     @default(0)

  // Financial readiness
  financialsComplete    Boolean   @default(false)
  rpcEstimate           Decimal?
  offerAmount           Decimal?

  // Compliance status
  allReturnsFiled       Boolean   @default(false)
  currentOnEstimates    Boolean   @default(false)
  poaOnFile             Boolean   @default(false)
  poaExpirationDate     DateTime?

  // Risk indicators
  levyThreatActive      Boolean   @default(false)
  liensFiledActive      Boolean   @default(false)
  csedEarliest          DateTime?
  csedLatest            DateTime?

  // Last AI assessment
  lastAssessmentDate    DateTime?
  lastAssessmentSummary String?   @db.Text

  // Activity
  lastActivityDate      DateTime  @default(now())
  lastActivityBy        String?
  lastActivityAction    String?

  // === V2: Case Graph Engine ===

  // Case Digest — precomputed natural language summary
  digest                String?   @db.Text
  digestUpdatedAt       DateTime?

  // Next Steps — structured, prioritized recommendations
  // Array of { priority: "critical"|"high"|"normal", action, reason, type, blockedBy?, suggestedBanjoBundle? }
  nextSteps             Json?
  nextStepsUpdatedAt    DateTime?

  // Bundle Readiness — what Banjo can produce right now
  // { oicPacket: "ready"|"blocked"|"partial", ... }
  bundleReadiness       Json?

  // Risk Score — 0-100, higher = more urgent
  riskScore             Int       @default(0)
  riskFactors           Json?

  // Staleness
  daysSinceActivity     Int       @default(0)
  isStale               Boolean   @default(false)

  // Confidence — how reliable is the intelligence?
  confidenceScore       Int       @default(0)
  confidenceFlags       Json?

  // Prior Similar Cases — for precedent matching
  similarCaseIds        Json?

  // Case Outcome — recorded when case reaches RESOLVED/CLOSED
  outcomeType           String?   // ACCEPTED, REJECTED, SETTLED, WITHDRAWN, EXPIRED
  outcomeAmount         Decimal?  // Final accepted/settled amount
  outcomeDate           DateTime?
  outcomeNotes          String?   @db.Text

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("case_intelligence")
}

model CaseActivity {
  id          String   @id @default(cuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation("CaseActivities", fields: [userId], references: [id])

  action      String
  description String
  metadata    Json?

  createdAt   DateTime @default(now())

  @@index([caseId, createdAt])
  @@map("case_activities")
}

model BanjoAssignment {
  id                String            @id @default(cuid())
  caseId            String
  case              Case              @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // The practitioner's original assignment text
  assignmentText    String            @db.Text

  // Orchestrator output
  clarifications    Json?
  plan              Json
  assumptions       Json?

  // Execution state
  status            BanjoStatus       @default(PLANNING)
  currentStep       Int               @default(0)
  totalSteps        Int               @default(0)

  // Revision pass
  revisionRan       Boolean           @default(false)
  revisionResult    String?           @db.Text
  revisedTaskIds    Json?
  skipRevision      Boolean           @default(false)

  // Metadata
  model             String            @default("claude-opus-4-6")
  createdById       String
  createdBy         User              @relation(fields: [createdById], references: [id])
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  tasks             AITask[]

  @@index([caseId])
  @@map("banjo_assignments")
}

model EditHistory {
  id              String   @id @default(cuid())
  aiTaskId        String
  caseType        String
  taskType        String
  originalOutput  String   @db.Text
  editedOutput    String   @db.Text
  practitionerId  String
  createdAt       DateTime @default(now())

  @@index([caseType, taskType])
  @@map("edit_history")
}

model RejectionFeedback {
  id              String   @id @default(cuid())
  aiTaskId        String
  caseType        String
  taskType        String
  correctionNotes String   @db.Text
  practitionerId  String
  createdAt       DateTime @default(now())

  @@index([caseType, taskType])
  @@map("rejection_feedback")
}

model Task {
  id              String    @id @default(cuid())
  title           String
  description     String?   @db.Text
  createdById     String
  createdBy       User      @relation("CreatedTasks", fields: [createdById], references: [id])
  assigneeId      String?
  assignee        User?     @relation("AssignedTasks", fields: [assigneeId], references: [id])
  dueDate         DateTime?
  completedAt     DateTime?
  completedById   String?
  completedBy     User?     @relation("CompletedTasks", fields: [completedById], references: [id])
  status          String    @default("open")
  priority        String    @default("normal")
  caseId          String?
  case            Case?     @relation(fields: [caseId], references: [id])
  deadlineId      String?
  feedPosts       FeedPost[] @relation("TaskFeedPosts")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([assigneeId, status])
  @@index([caseId])
  @@index([dueDate])
  @@map("tasks")
}

model FeedPost {
  id          String       @id @default(cuid())

  // Author
  authorId    String?      // null for system events and Junebug
  author      User?        @relation("FeedPosts", fields: [authorId], references: [id])
  authorType  String       @default("user")  // "user", "system", "junebug"

  // Source linkage (V2 — what generated this post)
  sourceType  String?      // "task", "banjo", "deadline", "review", "document", null=user-authored
  sourceId    String?      // ID of the source entity
  taskId      String?      // Direct FK to Task (when sourceType = "task")
  task        Task?        @relation("TaskFeedPosts", fields: [taskId], references: [id])

  // Content
  postType    String       // "post", "task", "task_created", "task_completed", "system_event", "file_share", "junebug_insight"
  content     String?      @db.Text  // The text body (markdown supported)

  // Case tagging (legacy — primary case)
  caseId      String?      // Primary case this post is about
  case        Case?        @relation(fields: [caseId], references: [id])

  // Task-specific fields (legacy compat — kept for existing queries)
  taskTitle       String?
  taskAssigneeId  String?
  taskAssignee    User?     @relation("AssignedFeedTasks", fields: [taskAssigneeId], references: [id])
  taskDueDate     DateTime?
  taskCompleted   Boolean   @default(false)
  taskCompletedAt DateTime?
  taskCompletedById String?

  // File attachment fields (legacy — use FeedAttachment for new posts)
  attachments  Json?       // Array of { fileName, fileUrl, fileType, fileSize }

  // System event metadata
  eventType    String?     // "banjo_complete", "document_upload", "deadline_warning", "review_approved", etc.
  eventData    Json?       // Structured data for rendering system events

  // Engagement
  replyCount   Int         @default(0)
  likeCount    Int         @default(0)

  // Mentions (legacy — use FeedMention for new posts)
  mentions     Json?       // Array of { type: "user"|"junebug"|"case", id: string, display: string }

  // Visibility
  pinned       Boolean     @default(false)
  archived     Boolean     @default(false)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  replies      FeedReply[]
  likes        FeedLike[]
  reactions    FeedReaction[]
  feedMentions FeedMention[]
  cases        FeedPostCase[]
  feedAttachments FeedAttachment[]

  @@index([createdAt])
  @@index([caseId])
  @@index([authorId])
  @@index([postType])
  @@index([taskAssigneeId, taskCompleted])
  @@index([taskId])
  @@map("feed_posts")
}

model FeedReply {
  id        String    @id @default(cuid())
  postId    String
  post      FeedPost  @relation(fields: [postId], references: [id], onDelete: Cascade)

  authorId    String?
  author      User?   @relation("FeedReplies", fields: [authorId], references: [id])
  authorType  String  @default("user")  // "user", "junebug"

  content   String?   @db.Text

  createdAt DateTime  @default(now())

  @@index([postId, createdAt])
  @@map("feed_replies")
}

model FeedLike {
  id      String   @id @default(cuid())
  postId  String
  post    FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId  String
  user    User     @relation("FeedLikes", fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@map("feed_likes")
}

model FeedReaction {
  id        String   @id @default(cuid())
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("FeedReactions", fields: [userId], references: [id])
  type      String
  createdAt DateTime @default(now())

  @@unique([postId, userId, type])
  @@map("feed_reactions")
}

model FeedPostCase {
  id      String   @id @default(cuid())
  postId  String
  post    FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  caseId  String
  case    Case     @relation("FeedPostCases", fields: [caseId], references: [id])

  @@unique([postId, caseId])
  @@index([caseId])
  @@map("feed_post_cases")
}

model FeedMention {
  id          String    @id @default(cuid())
  postId      String
  post        FeedPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  mentionType String
  userId      String?
  user        User?     @relation("FeedMentions", fields: [userId], references: [id])
  display     String

  @@index([userId])
  @@index([postId])
  @@map("feed_mentions")
}

model FeedAttachment {
  id        String   @id @default(cuid())
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())

  @@map("feed_attachments")
}

// ═══════════════════════════════════════════════════════════════
// CLIENT NOTES & PRACTITIONER CONVERSATIONS
// ═══════════════════════════════════════════════════════════════

model ClientNote {
  id              String         @id @default(cuid())
  caseId          String
  case            Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorId        String
  author          User           @relation("NoteAuthor", fields: [authorId], references: [id])
  noteType        NoteType       @default(GENERAL)
  title           String?
  content         String         @db.Text
  taxYears        Int[]          @default([])
  relatedFeature  FeatureArea?
  pinned          Boolean        @default(false)
  visibility      NoteVisibility @default(ALL_PRACTITIONERS)
  isDeleted       Boolean        @default(false)
  isPrivileged    Boolean        @default(false)
  // Call log fields
  callDate        DateTime?
  callDuration    Int?           // minutes
  callParticipants String?
  callType        String?        // inbound, outbound
  callDisposition String?
  // IRS contact fields
  irsEmployeeName String?
  irsEmployeeId   String?
  irsDepartment   String?
  irsContactMethod String?      // phone, fax, mail, in-person
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  attachments     NoteAttachment[]

  @@index([caseId, createdAt])
  @@index([authorId])
  @@index([noteType])
  @@index([caseId, pinned])
  @@map("client_notes")
}

model NoteAttachment {
  id         String     @id @default(cuid())
  noteId     String
  note       ClientNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  documentId String?
  fileName   String
  fileUrl    String
  fileType   String
  fileSize   Int
  createdAt  DateTime   @default(now())

  @@map("note_attachments")
}

model Conversation {
  id               String               @id @default(cuid())
  caseId           String
  case             Case                 @relation(fields: [caseId], references: [id], onDelete: Cascade)
  startedById      String
  startedBy        User                 @relation("ConversationStarter", fields: [startedById], references: [id])
  subject          String
  status           ConversationStatus   @default(OPEN)
  priority         ConversationPriority @default(NORMAL)
  relatedTaxYears  Int[]                @default([])
  relatedFeature   FeatureArea?
  participants     String[]             @default([])
  resolvedAt       DateTime?
  resolvedById     String?
  resolvedBy       User?                @relation("ConversationResolver", fields: [resolvedById], references: [id])
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  messages         ConversationMsg[]

  @@index([caseId, status])
  @@index([startedById])
  @@map("conversations")
}

model ConversationMsg {
  id              String       @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId        String
  author          User         @relation("MessageAuthor", fields: [authorId], references: [id])
  content         String       @db.Text
  isEdited        Boolean      @default(false)
  isDeleted       Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  attachments     ConversationMsgAttachment[]

  @@index([conversationId, createdAt])
  @@map("conversation_messages")
}

model ConversationMsgAttachment {
  id         String          @id @default(cuid())
  messageId  String
  message    ConversationMsg @relation(fields: [messageId], references: [id], onDelete: Cascade)
  documentId String?
  fileName   String
  fileUrl    String
  fileType   String
  fileSize   Int
  createdAt  DateTime        @default(now())

  @@map("conversation_msg_attachments")
}

// ═══════════════════════════════════════════════════════════════
// SOC 2 COMPLIANCE TRACKER
// ═══════════════════════════════════════════════════════════════

model ComplianceControl {
  id                   String           @id @default(cuid())
  controlId            String           @unique // CC1.1, A1.1, PI1.1, etc.
  tsc                  TSC
  controlFamily        String           // CC1, CC2, A1, PI1, C1, P1, etc.
  description          String           @db.Text
  monitoringMethod     MonitoringMethod @default(MANUAL)
  status               ControlStatus    @default(NOT_ASSESSED)
  whatSoc2Requires     String           @db.Text
  howClearedMeetsIt    String           @db.Text
  whyItMatters         String           @db.Text
  ownerId              String?
  lastEvidenceCollected DateTime?
  nextReviewDate       DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  healthChecks         HealthCheck[]
  issues               ComplianceIssue[]
  evidence             EvidenceItem[]

  @@index([tsc])
  @@index([controlFamily])
  @@index([status])
  @@map("compliance_controls")
}

model HealthCheck {
  id          String            @id @default(cuid())
  controlId   String
  control     ComplianceControl @relation(fields: [controlId], references: [id], onDelete: Cascade)
  checkType   String            // automated, manual
  interval    String            // 15m, 1h, daily, weekly
  lastRun     DateTime?
  lastResult  String?           // pass, fail, warning
  nextRun     DateTime?
  createdAt   DateTime          @default(now())
  results     HealthCheckResult[]

  @@index([controlId])
  @@map("health_checks")
}

model HealthCheckResult {
  id               String      @id @default(cuid())
  healthCheckId    String
  healthCheck      HealthCheck @relation(fields: [healthCheckId], references: [id], onDelete: Cascade)
  timestamp        DateTime    @default(now())
  status           String      // pass, fail, warning
  details          Json?
  evidenceSnapshot Json?

  @@index([healthCheckId, timestamp])
  @@map("health_check_results")
}

model ComplianceIssue {
  id              String            @id @default(cuid())
  controlId       String
  control         ComplianceControl @relation(fields: [controlId], references: [id])
  severity        IssueSeverity
  status          IssueStatus       @default(OPEN)
  description     String            @db.Text
  remediationPlan String?           @db.Text
  ownerId         String?
  slaDeadline     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  resolvedAt      DateTime?

  @@index([controlId])
  @@index([severity, status])
  @@map("compliance_issues")
}

model EvidenceItem {
  id            String            @id @default(cuid())
  controlId     String
  control       ComplianceControl @relation(fields: [controlId], references: [id])
  evidenceType  EvidenceType
  collectedAt   DateTime          @default(now())
  contentOrPath String            @db.Text
  collector     String            // "system" or userId
  validUntil    DateTime?
  createdAt     DateTime          @default(now())

  @@index([controlId])
  @@map("evidence_items")
}

model AuditMilestone {
  id          String          @id @default(cuid())
  title       String
  description String?         @db.Text
  targetDate  DateTime
  status      MilestoneStatus @default(NOT_STARTED)
  notes       String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("audit_milestones")
}

// ═══════════════════════════════════════════════════════════════
// SOC 2 POLICY ACKNOWLEDGMENT GATE (CC1.1, CC2.2, CC5.3)
// ═══════════════════════════════════════════════════════════════

model CompliancePolicy {
  id            String   @id @default(cuid())
  slug          String   @unique // "code-of-conduct", "security-policy", "data-handling", "acceptable-use", "incident-response"
  title         String
  content       String   @db.Text // The policy content (markdown)
  version       Int      @default(1)
  effectiveDate DateTime @default(now())
  createdById   String
  createdBy     User     @relation("PolicyCreator", fields: [createdById], references: [id])
  isActive      Boolean  @default(true)
  acknowledgments PolicyAcknowledgment[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slug, version])
  @@map("compliance_policies")
}

model PolicyAcknowledgment {
  id         String   @id @default(cuid())
  policyId   String
  policy     CompliancePolicy @relation(fields: [policyId], references: [id])
  userId     String
  user       User     @relation("PolicyAcknowledgments", fields: [userId], references: [id])
  version    Int      // The version they acknowledged
  acknowledgedAt DateTime @default(now())
  ipAddress  String?

  @@unique([policyId, userId, version])
  @@index([userId])
  @@map("policy_acknowledgments")
}

model SecurityTraining {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation("SecurityTrainings", fields: [userId], references: [id])
  moduleId      String   // "data-handling", "phishing", "incident-reporting", "client-confidentiality"
  moduleName    String
  version       Int      @default(1)
  score         Int?     // Quiz score (0-100)
  passed        Boolean  @default(false)
  completedAt   DateTime @default(now())

  @@unique([userId, moduleId, version])
  @@index([userId])
  @@map("security_trainings")
}

model BackgroundCheck {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("BackgroundChecks", fields: [userId], references: [id])
  provider     String   // "Sterling", "Checkr", etc.
  dateCompleted DateTime
  result       String   // "CLEAR", "FLAGGED", "PENDING"
  nextCheckDate DateTime?
  notes        String?  @db.Text
  enteredById  String
  enteredBy    User     @relation("BackgroundCheckEntries", fields: [enteredById], references: [id])
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("background_checks")
}

model GovernanceMeeting {
  id          String   @id @default(cuid())
  meetingDate DateTime
  attendeeIds String[] // User IDs
  agenda      String   @db.Text
  decisions   String   @db.Text
  actionItems Json     // Array of { description, assigneeId, dueDate, status }
  quarter     String   // "2026-Q1"
  createdById String
  createdBy   User     @relation("GovernanceMeetings", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("governance_meetings")
}

model VendorRecord {
  id                String   @id @default(cuid())
  name              String   @unique
  service           String   // What service they provide
  dataShared        String   // What data is shared with them
  integrationType   String   // "API", "SDK", "Cloud Infrastructure", "SaaS"
  soc2ReportDate    DateTime? // When their SOC 2 report was issued
  soc2ExpiryDate    DateTime? // When it expires
  dpaStatus         String   @default("NOT_STARTED") // "NOT_STARTED", "IN_PROGRESS", "SIGNED"
  lastAssessmentDate DateTime?
  riskLevel         String   @default("MEDIUM") // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("vendor_records")
}

model IncidentRecord {
  id              String   @id @default(cuid())
  title           String
  severity        String   // "CRITICAL", "HIGH", "MEDIUM", "LOW"
  status          String   @default("DETECTED") // "DETECTED", "CLASSIFIED", "RESPONDING", "RESOLVED", "POST_MORTEM"
  classification  String?  // "unauthorized_access", "data_breach", "configuration_drift", "anomalous_export", etc.
  description     String   @db.Text
  detectedAt      DateTime @default(now())
  detectedBy      String   // "system" or userId
  assignedToId    String?
  assignedTo      User?    @relation("IncidentAssignee", fields: [assignedToId], references: [id])
  resolvedAt      DateTime?
  resolvedById    String?
  postMortemNotes String?  @db.Text
  rootCause       String?  @db.Text
  affectedClients Int      @default(0)
  affectedStates  String[] // For breach notification
  playbookSteps   Json?    // Array of { step, assignee, status, completedAt }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([severity])
  @@map("incident_records")
}

model DataDisposalRecord {
  id            String   @id @default(cuid())
  clientCount   Int
  recordCount   Int
  method        String   @default("CRYPTO_SHRED") // "CRYPTO_SHRED", "PHYSICAL_DESTRUCTION"
  status        String   @default("QUEUED") // "QUEUED", "CONFIRMED", "EXECUTED", "CERTIFIED"
  queuedAt      DateTime @default(now())
  confirmedById String?
  confirmedBy   User?    @relation("DisposalConfirmer", fields: [confirmedById], references: [id])
  confirmedAt   DateTime?
  executedAt    DateTime?
  certificateId String?  // Reference to generated certificate
  details       Json     // Array of { clientId, clientName, dataTypes, retentionExpiry }
  createdAt     DateTime @default(now())

  @@map("data_disposal_records")
}

model DataSubjectRequest {
  id            String   @id @default(cuid())
  requestType   String   // "ACCESS", "CORRECTION", "DELETION"
  subjectName   String
  subjectEmail  String
  description   String   @db.Text
  status        String   @default("RECEIVED") // "RECEIVED", "IN_PROGRESS", "COMPLETED", "DENIED"
  slaDeadline   DateTime // 30 days from receipt
  assignedToId  String?
  assignedTo    User?    @relation("DSRAssignee", fields: [assignedToId], references: [id])
  responseData  Json?    // Auto-compiled data package for access requests
  completedAt   DateTime?
  completedById String?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@map("data_subject_requests")
}

// ─── Form Builder Instances ───

model FormInstance {
  id                String   @id @default(cuid())
  formNumber        String
  caseId            String
  status            String   @default("draft")
  values            Json     @default("{}")
  completedSections String[] @default([])
  version           Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdById       String

  case              Case     @relation(fields: [caseId], references: [id])
  createdBy         User     @relation("FormInstances", fields: [createdById], references: [id])

  @@index([caseId])
  @@index([createdById])
  @@map("form_instances")
}

// ─── Junebug Feedback Pipeline ───

model JunebugObservation {
  id            String   @id @default(cuid())
  type          String
  severity      String   @default("LOW")
  title         String
  description   String   @db.Text
  route         String?
  caseId        String?
  userId        String?
  metadata      Json?
  syncedToTasks Boolean  @default(false)
  syncedAt      DateTime?
  createdAt     DateTime @default(now())

  @@index([type])
  @@index([syncedToTasks, createdAt])
  @@index([severity])
  @@map("junebug_observations")
}

// ── Reasoning Pipeline ────────────────────────────────────────────
// Logs every generate → evaluate → refine cycle for auditability.

model ReasoningPipelineLog {
  id                    String    @id @default(cuid())
  caseId                String?
  taskType              String
  originalRequest       String    @db.Text
  generationModel       String
  evaluationModel       String
  originalDraft         String    @db.Text
  revisedDraft          String?   @db.Text
  finalOutput           String    @db.Text
  firstEvaluation       Json
  secondEvaluation      Json?
  firstThinkingContent  String    @db.Text
  secondThinkingContent String?   @db.Text
  decision              String    // 'pass' | 'revise' | 'human_review'
  overallScore          Int
  revisionAttempted     Boolean   @default(false)
  deliveredToUser       Boolean   @default(false)
  totalLatencyMs        Int
  humanReviewedBy       String?
  humanReviewedAt       DateTime?
  humanReviewAction     String?   // 'approved' | 'rejected' | 'edited'
  humanReviewNotes      String?   @db.Text
  createdAt             DateTime  @default(now())

  case                  Case?     @relation(fields: [caseId], references: [id])

  @@index([caseId])
  @@index([taskType])
  @@index([decision])
  @@index([createdAt])
  @@map("reasoning_pipeline_logs")
}

// ── Work Product Controls ─────────────────────────────────────────
// Per-user, per-task-type AI output customization.

model WorkProductOverride {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation("WorkProductOverrides", fields: [userId], references: [id], onDelete: Cascade)
  taskType            String
  isEnabled           Boolean   @default(true)
  toneDirective       String?   @db.Text
  structureDirective  String?   @db.Text
  lengthDirective     String?   @db.Text
  emphasisAreas       String?   @db.Text
  avoidances          String?   @db.Text
  customInstructions  String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  examples            WorkProductExample[]

  @@unique([userId, taskType])
  @@index([userId])
  @@map("work_product_overrides")
}

model WorkProductExample {
  id              String    @id @default(cuid())
  overrideId      String
  override        WorkProductOverride @relation(fields: [overrideId], references: [id], onDelete: Cascade)
  label           String
  content         String    @db.Text
  isGoodExample   Boolean   @default(true)
  notes           String?   @db.Text
  sourceFileName  String?
  sourceFileType  String?
  sourceFilePath  String?
  createdAt       DateTime  @default(now())

  @@index([overrideId])
  @@map("work_product_examples")
}
