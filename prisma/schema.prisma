generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PRACTITIONER
  SENIOR
  ADMIN
  SUPPORT_STAFF
}

enum LicenseType {
  EA
  CPA
  ATTORNEY
}

enum CaseStatus {
  INTAKE
  ANALYSIS
  REVIEW
  ACTIVE
  RESOLVED
  CLOSED
}

enum CaseType {
  OIC
  IA
  PENALTY
  INNOCENT_SPOUSE
  CNC
  TFRP
  ERC
  UNFILED
  AUDIT
  CDP
  AMENDED
  VOLUNTARY_DISCLOSURE
  OTHER
}

enum FilingStatus {
  SINGLE
  MFJ
  MFS
  HOH
  QSS
}

enum FileType {
  PDF
  IMAGE
  DOCX
  XLSX
  TEXT
}

enum DocumentCategory {
  IRS_NOTICE
  IRS_REJECTION
  BANK_STATEMENT
  TAX_RETURN
  PAYROLL
  MEDICAL
  MEETING_NOTES
  UTILITY_BILL
  VEHICLE_LOAN
  STUDENT_LOAN
  RETIREMENT_ACCOUNT
  MORTGAGE_STATEMENT
  INSURANCE
  PAY_STUB
  OTHER
}

enum AITaskType {
  WORKING_PAPERS
  CASE_MEMO
  PENALTY_LETTER
  OIC_NARRATIVE
  GENERAL_ANALYSIS
  IA_ANALYSIS
  CNC_ANALYSIS
  TFRP_ANALYSIS
  INNOCENT_SPOUSE_ANALYSIS
  APPEALS_REBUTTAL
}

enum AITaskStatus {
  QUEUED
  PROCESSING
  READY_FOR_REVIEW
  APPROVED
  REJECTED
}

enum ReviewActionType {
  APPROVE
  EDIT_APPROVE
  REJECT_REPROMPT
  REJECT_MANUAL
}

enum KnowledgeCategory {
  IRC_STATUTE
  TREASURY_REGULATION
  IRM_SECTION
  REVENUE_PROCEDURE
  REVENUE_RULING
  CASE_LAW
  TREATISE
  FIRM_TEMPLATE
  WORK_PRODUCT
  APPROVED_OUTPUT
  FIRM_PROCEDURE
  TRAINING_MATERIAL
  CLIENT_GUIDE
  CUSTOM
}

enum MessageType {
  DIRECT_MESSAGE
  BUG_REPORT
  FEATURE_REQUEST
  DEADLINE_REMINDER
  REVIEW_ASSIGNED
  TASK_APPROVED
  TASK_REJECTED
  SYSTEM_ANNOUNCEMENT
  CASE_NOTE
}

enum MessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum DeadlineType {
  CDP_HEARING
  EQUIVALENT_HEARING
  TAX_COURT_PETITION
  CSED_EXPIRATION
  ASSESSMENT_STATUTE
  OIC_SUBMISSION
  OIC_PAYMENT
  OIC_COMPLIANCE
  IA_PAYMENT
  RETURN_DUE
  EXTENSION_DUE
  ESTIMATED_TAX
  IRS_RESPONSE
  DOCUMENT_REQUEST
  POA_RENEWAL
  FOLLOW_UP
  HEARING_DATE
  MEETING
  INTERNAL_REVIEW
  CUSTOM
}

enum DeadlinePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum DeadlineStatus {
  UPCOMING
  DUE_SOON
  OVERDUE
  COMPLETED
  WAIVED
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  passwordHash   String
  role           Role      @default(PRACTITIONER)
  licenseType    LicenseType?
  licenseNumber  String?
  mfaEnabled     Boolean   @default(false)
  mfaSecret      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  assignedCases       Case[]         @relation("AssignedPractitioner")
  uploadedDocs        Document[]
  reviewActions       ReviewAction[]
  auditLogs           AuditLog[]
  aiTasks             AITask[]
  completedDeadlines  Deadline[]     @relation("CompletedDeadlines")
  assignedDeadlines   Deadline[]     @relation("AssignedDeadlines")
  createdDeadlines    Deadline[]     @relation("CreatedDeadlines")
  uploadedKnowledge   KnowledgeDocument[] @relation("UploadedKnowledge")
  sentMessages        Message[]          @relation("SentMessages")
  receivedMessages    Message[]          @relation("ReceivedMessages")
  appErrors           AppError[]         @relation("UserErrors")
  implementedMessages Message[]          @relation("ImplementedMessages")
  caseActivities      CaseActivity[]     @relation("CaseActivities")

  @@map("users")
}

model Case {
  id                    String     @id @default(cuid())
  caseNumber            String     @unique
  clientName            String
  clientNameEncrypted   String?
  status                CaseStatus @default(INTAKE)
  caseType              CaseType   @default(OTHER)
  filingStatus          FilingStatus?
  clientEmail           String?
  clientPhone           String?
  totalLiability        Decimal?
  assignedPractitionerId String?
  assignedPractitioner  User?      @relation("AssignedPractitioner", fields: [assignedPractitionerId], references: [id])
  notes                 String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  documents         Document[]
  aiTasks           AITask[]
  tokenMaps         TokenMap[]
  auditLogs         AuditLog[]
  liabilityPeriods  LiabilityPeriod[]
  deadlines         Deadline[]
  messages          Message[]
  intelligence      CaseIntelligence?
  activities        CaseActivity[]

  @@map("cases")
}

model Document {
  id               String           @id @default(cuid())
  caseId           String
  case             Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fileName         String
  filePath         String
  fileType         FileType
  fileSize         Int
  documentCategory DocumentCategory @default(OTHER)
  extractedText    String?
  uploadedById     String
  uploadedBy       User             @relation(fields: [uploadedById], references: [id])
  uploadedAt       DateTime         @default(now())

  @@map("documents")
}

model AITask {
  id                  String       @id @default(cuid())
  caseId              String
  case                Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  taskType            AITaskType
  status              AITaskStatus @default(QUEUED)
  tokenizedInput      String?      @db.Text
  tokenizedOutput     String?      @db.Text
  detokenizedOutput   String?      @db.Text
  modelUsed           String?
  temperature         Float?
  systemPromptVersion String?
  verifyFlagCount     Int          @default(0)
  judgmentFlagCount    Int          @default(0)
  requestId           String       @unique @default(uuid())
  metadata            Json?
  casePosture         Json?
  createdById         String?
  createdBy           User?        @relation(fields: [createdById], references: [id])
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  reviewActions ReviewAction[]
  auditLogs     AuditLog[]

  @@map("ai_tasks")
}

model ReviewAction {
  id               String           @id @default(cuid())
  aiTaskId         String
  aiTask           AITask           @relation(fields: [aiTaskId], references: [id], onDelete: Cascade)
  practitionerId   String
  practitioner     User             @relation(fields: [practitionerId], references: [id])
  action           ReviewActionType
  editedOutput     String?          @db.Text
  reviewNotes      String?
  reviewStartedAt   DateTime
  reviewCompletedAt  DateTime?
  flagsAcknowledged  Boolean   @default(false)

  @@map("review_actions")
}

model AuditLog {
  id             String   @id @default(cuid())
  aiTaskId       String?
  aiTask         AITask?  @relation(fields: [aiTaskId], references: [id])
  practitionerId String?
  practitioner   User?    @relation(fields: [practitionerId], references: [id])
  caseId         String?
  case           Case?    @relation(fields: [caseId], references: [id])
  action         String
  metadata       Json?
  timestamp      DateTime @default(now())

  @@map("audit_logs")
}

model LiabilityPeriod {
  id                 String    @id @default(cuid())
  caseId             String
  case               Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  taxYear            Int
  formType           String    // "1040", "941", etc.
  originalAssessment Decimal?
  penalties          Decimal?
  interest           Decimal?
  totalBalance       Decimal?
  assessmentDate     DateTime?
  csedDate           DateTime?
  status             String?   // "assessed", "paid", etc.

  @@map("liability_periods")
}

model TokenMap {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tokenMap  String   @db.Text
  createdAt DateTime @default(now())
  expiresAt DateTime?

  @@map("token_maps")
}

model Deadline {
  id              String           @id @default(cuid())
  caseId          String
  case            Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type            DeadlineType
  priority        DeadlinePriority @default(MEDIUM)
  status          DeadlineStatus   @default(UPCOMING)
  title           String
  description     String?
  dueDate         DateTime
  reminderDate    DateTime?
  completedDate   DateTime?
  completedById   String?
  completedBy     User?            @relation("CompletedDeadlines", fields: [completedById], references: [id])
  assignedToId    String?
  assignedTo      User?            @relation("AssignedDeadlines", fields: [assignedToId], references: [id])
  createdById     String?
  createdBy       User?            @relation("CreatedDeadlines", fields: [createdById], references: [id])
  source          String?
  sourceTaskId    String?
  irsNoticeDate   DateTime?
  irsNoticeNumber String?
  taxYear         Int?
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([caseId])
  @@index([dueDate])
  @@index([status])
  @@index([assignedToId])
  @@map("deadlines")
}

model KnowledgeDocument {
  id              String            @id @default(cuid())
  title           String
  description     String?
  category        KnowledgeCategory
  fileName        String?
  filePath        String?
  fileSize        Int?
  s3Key           String?
  processingStatus String           @default("ready") // uploading | processing | ready | failed
  processingError String?
  sourceText      String            @db.Text @default("")
  tags            String[]
  isActive        Boolean           @default(true)
  chunkCount      Int               @default(0)
  hitCount        Int               @default(0)
  uploadedById    String
  uploadedBy      User              @relation("UploadedKnowledge", fields: [uploadedById], references: [id])
  sourceTaskId    String?
  sourceCaseId    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  chunks          KnowledgeChunk[]

  @@index([category])
  @@index([isActive])
  @@index([processingStatus])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id              String            @id @default(cuid())
  documentId      String
  document        KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex      Int
  content         String            @db.Text
  sectionHeader   String?
  tokenCount      Int?
  hitCount        Int               @default(0)
  metadata        Json?
  createdAt       DateTime          @default(now())

  // Managed via raw SQL in vector-setup.ts (pgvector extension)
  embedding       Unsupported("vector(1536)")?
  // search_vector is a GENERATED ALWAYS AS ... STORED tsvector column.
  // It cannot be declared here because Prisma tries to ALTER generated columns.
  // It is dropped before `prisma db push` and recreated by setup-vector.mjs.

  @@index([documentId])
  @@map("knowledge_chunks")
}

model AppError {
  id            String   @id @default(cuid())
  route         String
  method        String
  errorMessage  String   @db.Text
  errorStack    String?  @db.Text
  statusCode    Int?
  userId        String?
  user          User?    @relation("UserErrors", fields: [userId], references: [id])
  caseId        String?
  aiTaskId      String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([route])
  @@index([userId])
  @@index([createdAt])
  @@map("app_errors")
}

model Message {
  id            String          @id @default(cuid())
  type          MessageType
  priority      MessagePriority @default(NORMAL)
  subject       String
  body          String          @db.Text

  senderId      String?
  sender        User?           @relation("SentMessages", fields: [senderId], references: [id])
  senderName    String?

  recipientId   String
  recipient     User            @relation("ReceivedMessages", fields: [recipientId], references: [id])

  read          Boolean         @default(false)
  readAt        DateTime?
  archived      Boolean         @default(false)

  caseId        String?
  case          Case?           @relation(fields: [caseId], references: [id], onDelete: SetNull)
  deadlineId    String?
  aiTaskId      String?

  parentId      String?
  parent        Message?        @relation("Replies", fields: [parentId], references: [id], onDelete: SetNull)
  replies       Message[]       @relation("Replies")

  tags          String[]
  metadata      Json?

  // Implementation tracking (for BUG_REPORT and FEATURE_REQUEST)
  implementationStatus  String?
  implementationNotes   String?   @db.Text
  implementedAt         DateTime?
  implementedById       String?
  implementedBy         User?     @relation("ImplementedMessages", fields: [implementedById], references: [id])

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([recipientId, read])
  @@index([recipientId, type])
  @@index([type, createdAt])
  @@index([caseId])
  @@map("messages")
}

model CaseIntelligence {
  id                    String    @id @default(cuid())
  caseId                String    @unique
  case                  Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Resolution tracking
  resolutionType        String?
  resolutionPhase       String    @default("GATHERING_DOCUMENTS")

  // IRS position tracking
  irsLastAction         String?
  irsLastActionDate     DateTime?
  irsNextExpectedAction String?
  irsAssignedUnit       String?
  irsAssignedEmployee   String?
  irsEmployeeId         String?

  // Document completeness
  docsRequired          Json      @default("[]")
  docsReceivedCount     Int       @default(0)
  docsRequiredCount     Int       @default(0)
  docCompleteness       Float     @default(0)

  // Financial readiness
  financialsComplete    Boolean   @default(false)
  rpcEstimate           Decimal?
  offerAmount           Decimal?

  // Compliance status
  allReturnsFiled       Boolean   @default(false)
  currentOnEstimates    Boolean   @default(false)
  poaOnFile             Boolean   @default(false)
  poaExpirationDate     DateTime?

  // Risk indicators
  levyThreatActive      Boolean   @default(false)
  liensFiledActive      Boolean   @default(false)
  csedEarliest          DateTime?
  csedLatest            DateTime?

  // Last AI assessment
  lastAssessmentDate    DateTime?
  lastAssessmentSummary String?   @db.Text

  // Activity
  lastActivityDate      DateTime  @default(now())
  lastActivityBy        String?
  lastActivityAction    String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("case_intelligence")
}

model CaseActivity {
  id          String   @id @default(cuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation("CaseActivities", fields: [userId], references: [id])

  action      String
  description String
  metadata    Json?

  createdAt   DateTime @default(now())

  @@index([caseId, createdAt])
  @@map("case_activities")
}
